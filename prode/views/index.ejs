<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <meta name="description" content="Aplicacion web para organizar un prode del Mundial 2026." />
    <link rel="stylesheet" href="/stylesheets/base.css" />
    <link rel="stylesheet" href="/stylesheets/home.css" />
    <link rel="stylesheet" href="/stylesheets/predictions.css" />
    <link rel="stylesheet" href="/stylesheets/ranking.css" />
    <link rel="stylesheet" href="/stylesheets/admin.css" />
    <link rel="stylesheet" href="/stylesheets/dialogs.css" />
  </head>
  <body>
    <header class="app-header">
      <div>
        <p class="eyebrow">Mundial 2026</p>
        <img class="brand-logo" src="/images/cencopay-logo.svg" alt="Logo" />
      </div>
      <div class="header-actions">
        <% if (locals.usuario) { %>
          <span class="session-pill">Hola, <%= locals.usuario.username %></span>
          <a href="/users/logout" class="button">Logout</a>
        <% } else { %>
          <a href="/users/login" class="button">Login</a>
          <a href="/users/register" class="button secondary">Register</a>
        <% } %>
      </div>
    </header>

    <main class="app-shell">
      <section class="score-strip">
        <article class="summary-carousel">
          <div class="carousel-copy">
            <p id="summaryKicker">Resumen</p>
            <span class="carousel-date"><%= data.currentDate %></span>
            <strong id="summaryValue">Prode activo</strong>
            <span id="summaryMeta">Base de datos Sequelize + MySQL</span>
          </div>
        </article>
      </section>

      <nav class="tabs" aria-label="Secciones">
        <a class="tab active" href="#homePanel">Inicio</a>
        <% if (locals.usuario) { %>
          <a class="tab" href="#predictionsPanel">Pronosticos</a>
          <a class="tab" href="#rankingPanel">Ranking</a>
        <% } %>
      </nav>

      <%- include('partials/home') %>
      <%- include('partials/predictions') %>
      <%- include('partials/ranking') %>
    </main>
  </body>
</html>
