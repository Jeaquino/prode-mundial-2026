<section class="panel" id="predictionsPanel">
  <div class="rules-card">
    <h2>Pronosticos</h2>
    <% if (locals.usuario) { %>
      <p>Elegí un partido y cargá tu marcador. Una vez guardado, el pronóstico queda fijo y ya no se puede editar.</p>
      <p>Total de partidos: <%= data.matches.length %></p>
      <div class="predictions-list">
        <% let currentGroup = null; %>
        <% data.matches.forEach(match => { %>
          <% if (match.isKnockout) { %>
            <% if (currentGroup !== 'KO') { currentGroup = 'KO'; %>
              <div class="zone-separator"><span>Eliminacion</span></div>
            <% } %>
          <% } else if (match.group !== currentGroup) { currentGroup = match.group; %>
            <div class="zone-separator">
              <span><%= match.group ? `Grupo ${match.group}` : 'Eliminacion' %></span>
            </div>
          <% } %>
          <% const existing = match.prediction && match.prediction.locked; %>
          <article class="prediction-item <%= existing ? 'locked' : '' %>">
            <div>
              <div class="match-group-label"><%= match.group ? `Grupo ${match.group}` : 'Eliminacion' %></div>
              <strong><%= match.home %> vs <%= match.away %></strong>
              <p><%= match.stage %> · <%= new Date(match.dateTime).toLocaleString('es-AR') %></p>
              <p><%= match.stadium || 'Sin estadio' %></p>
              <p class="prediction-note"><%= existing ? 'Pronostico ya guardado y bloqueado' : 'Antes de guardar: este pronostico no se podra modificar' %></p>
            </div>
            <div class="prediction-actions">
              <form method="post" action="/api/pronosticos" class="prediction-form">
                <input type="hidden" name="partido_id" value="<%= match.id %>" />
                <input type="number" name="goles_local_predicho" min="0" placeholder="0" required <%= existing ? 'disabled' : '' %> />
                <input type="number" name="goles_visitante_predicho" min="0" placeholder="0" required <%= existing ? 'disabled' : '' %> />
                <button class="button secondary" type="submit" <%= existing ? 'disabled' : '' %>><%= existing ? 'Guardado' : 'Guardar' %></button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
      <div class="phase-grid">
        <section class="phase-card"><h3>16avos</h3><div class="phase-slots"><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div></div></section>
        <section class="phase-card"><h3>Octavos</h3><div class="phase-slots"><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div></div></section>
        <section class="phase-card"><h3>Cuartos</h3><div class="phase-slots"><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div></div></section>
        <section class="phase-card"><h3>Semifinal</h3><div class="phase-slots"><div class="phase-slot">TBD</div><div class="phase-slot">TBD</div></div></section>
        <section class="phase-card"><h3>Final</h3><div class="phase-slots"><div class="phase-slot">TBD</div></div></section>
        <section class="phase-card"><h3>3er puesto</h3><div class="phase-slots"><div class="phase-slot">TBD</div></div></section>
      </div>
    <% } else { %>
      <p>Iniciá sesión para cargar tus pronosticos.</p>
    <% } %>
  </div>
</section>
