<section class="panel" id="predictionsPanel">
  <div class="toolbar">
    <div>
      <h2>Partidos para predecir</h2>
      <p>Modo oficial: solo se cargan pronosticos para partidos desbloqueados.</p>
    </div>
    <div class="filters" role="group" aria-label="Filtros">
      <button class="chip active" data-filter="open" type="button">Abiertos</button>
      <button class="chip" data-filter="all" type="button">Todos</button>
      <button class="chip" data-filter="finished" type="button">Finalizados</button>
      <button class="button" id="commitPredictionsButton" type="button">Confirmar pronosticos</button>
    </div>
  </div>
  <div class="match-grid" id="predictionList"></div>
</section>
