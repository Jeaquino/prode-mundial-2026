<!doctype html>
<html lang="es">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <meta name="description" content="Aplicacion web para organizar un prode del Mundial 2026 con grupos privados, reglas de puntaje y ranking." />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="stylesheet" href="/stylesheets/base.css" />
  <link rel="stylesheet" href="/stylesheets/home.css" />
  <link rel="stylesheet" href="/stylesheets/predictions.css" />
  <link rel="stylesheet" href="/stylesheets/ranking.css" />
  <link rel="stylesheet" href="/stylesheets/admin.css" />
  <link rel="stylesheet" href="/stylesheets/dialogs.css" />
</head>

<body>
  <header class="app-header">
    <div>
      <p class="eyebrow">Mundial 2026</p>
      <img class="brand-logo" src="/images/cencopay-logo.svg" alt="CencoPay" />
    </div>
    <div class="header-actions">
      <!-- <span class="session-pill" id="sessionStatus">Sin sesion</span> -->
      <% if (locals.usuario) { %>
      <span class="session-pill">Hola, <%= locals.usuario.username %></span>

      <a href="/users/logout">
        <button class="button" id="logoutButton" type="button">Logout</button>
      </a>

      <%}else{%>

      <a href="/users/login">
        <button class="button" id="loginButton" type="button">Login</button>
      </a>
      <!-- <button class="button secondary" id="adminLoginButton" type="button">Admin</button> -->
      <a href="/users/register">
        <button class="button secondary" id="adminLoginButton" type="button">register</button>
      </a>
      <% } %>
      <!-- <button class="button secondary hidden" id="logoutButton" type="button">Salir</button> -->
    </div>
  </header>

  <main class="app-shell">
    <section class="score-strip" aria-label="Resumen">
      <article class="summary-carousel">
        <div class="carousel-copy">
          <p id="summaryKicker">Resumen</p>
          <span class="carousel-date hidden" id="summaryDate"></span>
          <strong id="summaryValue">Cargando...</strong>
          <span id="summaryMeta">Preparando el prode.</span>
        </div>
        <div class="carousel-dots" id="summaryDots" aria-hidden="true"></div>
      </article>
    </section>

    <nav class="tabs" aria-label="Secciones">
      <button class="tab active" data-tab="home" type="button">Inicio</button>
      <% if (locals.usuario) { %>
      <button class="tab" data-tab="predictions" type="button">Pronosticos</button>
      <button class="tab" data-tab="ranking" type="button">Ranking</button>
      <% if (locals.usuario && locals.usuario.rol === 'admin') { %>
      <button class="tab" data-tab="admin" type="button">Admin</button>
      <% } %>
      <% } %>
    </nav>

<form class="admin-form" id="knockoutForm">
    <h3>Agregar partido de eliminacion</h3>
    <div class="form-grid">
      <label>
        Equipo A
        <input id="knockoutHome" required placeholder="Argentina" />
      </label>
      <label>
        Equipo B
        <input id="knockoutAway" required placeholder="Brasil" />
      </label>
      <label>
        Ronda
        <select id="knockoutRound">
          <option value="R32">16avos</option>
          <option value="R16">Octavos</option>
          <option value="QF">Cuartos</option>
          <option value="SF">Semifinal</option>
          <option value="F">Final</option>
        </select>
      </label>
      <button class="button" type="submit">Agregar</button>
    </div>
  </form>

  <div class="admin-list" id="adminMatchList"></div>

  <!-- TABLA DE USUARIOS -->
  <div class="admin-section">
    <h3>Gestión de Usuarios</h3>
    <div class="table-responsive">
      <table class="admin-table" id="usuariosTable">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>PIN</th>
            <th>Es Admin</th>
            <th>Creado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="usuariosTableBody">
          <% users.map(user => {%>
          <tr>
            <td><%=user.id%></td>
            <td><%=user.name%></td>
            <td><%=user.email%></td>
            <td><%=user.pin%></td>
            <td><%=user.isAdmin ? 'Yes' : 'No'%></td>
            <td><%=new Date(user.createdAt).toLocaleDateString()%></td>
            <td>
              <button class="button">Editar</button>
              <button class="button">Eliminar</button>
            </td>
            <% }) %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- TABLA DE PARTIDOS -->
  <div class="admin-section">
    <h3>Gestión de Partidos</h3>
    <div class="table-responsive">
      <table class="admin-table" id="partidosTable">
        <thead>
          <tr>
            <th>Equipo Local</th>
            <th>Equipo Visitante</th>
            <th>Fecha</th>
            <th>Goles Local</th>
            <th>Goles Visitante</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>

        </thead>
        <tbody id="partidosTableBody">
          <% partidos.map(partido => {%>
          <tr>
            <td><%= partido.local.nombre %></td>
            <td><%= partido.visitante.nombre %></td>
            <td><%= partido.fecha %></td>
            <td><%= partido.goles_local %></td>
            <td><%= partido.goles_visitante %></td>
            <td><%= partido.estado %></td>
            <td><button class="button">Editar</button></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>

</html>
